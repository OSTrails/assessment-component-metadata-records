<https://ostrails.github.io/assessment-component-metadata-records/benchmark/FB-LWERIC.ttl> a ftr:Benchmark, dcat:Resource ;
    dcterms:identifier "https://ostrails.github.io/assessment-component-metadata-records/benchmark/FB-LWERIC.ttl"^^xsd:string ;
    rdfs:isDefinedBy "https://ostrails.github.io/assessment-component-metadata-records/benchmark/FB-LWERIC.ttl"^^xsd:anyURI ;
    dcat:landingPage "https://ostrails.github.io/assessment-component-metadata-records/benchmark/FB-LWERIC.ttl"^^xsd:anyURI ;
    dcterms:title "FAIR Benchmark - LifeWatch ERIC Metadata Catalogue"^^xsd:string ;
    rdfs:label "FB-LWERIC"^^xsd:string ;
    vivo:abbreviation "FB-LWERIC"^^xsd:string ;
    dcterms:description """This benchmark defines the criteria for assessing the FAIRness of metadata records published in the LifeWatch ERIC Metadata Catalogue. It has been developed within the framework of the OSTrails project, as part of Use Case 4, and represents an ongoing effort to define and refine FAIR assessment criteria for LifeWatch ERIC resources."""^^xsd:string ;
    dcat:keyword "Taxonomic classification"^^xsd:string, "climate"^^xsd:string, "ecosystem"^^xsd:string, "marine metagenome"^^xsd:string ;
    schema:about "All"^^xsd:string ;
    ftr:applicationArea <http://aims.fao.org/aos/agrovoc/c_331559>, <http://edamontology.org/topic_0637>, <http://edamontology.org/topic_3050>, <http://edamontology.org/topic_3071>, <http://edamontology.org/topic_3174>, <http://edamontology.org/topic_3387>, <http://edamontology.org/topic_3573>, <http://purl.obolibrary.org/obo/NCIT_C16633> ;
    
    dcat:version "1.0.0"^^xsd:string ;
    
    
    ftr:status "Active"@en ;
     
    
    
    
    
    
    ftr:supportedBy <https://w3id.org/FAIR-Champion> ;
    dpv:IsApplicableFor <https://schema.org/Dataset>;
    dcterms:creator <https://ror.org/04c04g438>; 
    
    
    
    
    
    
    dcterms:publisher  <https://orcid.org/0000-0002-5935-6074> ,  <https://orcid.org/0000-0003-3330-2163>  ; 
    dcat:contactPoint  <https://orcid.org/0000-0002-5935-6074> ,  <https://orcid.org/0000-0003-3330-2163>  . 




<https://ror.org/04c04g438> a vcard:Organisation ;
    vcard:organisation-name "LifeWatch ERIC"^^xsd:string .

<https://orcid.org/0000-0002-5935-6074> a vcard:Individual, foaf:Agent ;
    vcard:fn "Lucia Vaira"^^xsd:string ;
    vcard:hasEmail <mailto:lucia.vaira@lifewatch.eu> .
    

  
