<https://ostrails.github.io/assessment-component-metadata-records/test/FT_F2_M_Discoverypublisher.ttl> a ftr:Test, dcat:DataService ;
    dcterms:identifier "https://ostrails.github.io/assessment-component-metadata-records/test/FT_F2_M_Discoverypublisher.ttl"^^xsd:string ;
    rdfs:isDefinedBy "https://ostrails.github.io/assessment-component-metadata-records/test/FT_F2_M_Discoverypublisher.ttl"^^xsd:anyURI ;
    dcat:landingPage "https://fairsharing.org/8022"^^xsd:anyURI ;
    dcterms:title "FAIR Test - F2 - Metadata - Has Publisher Information"^^xsd:string ;
    rdfs:label "FT_F2_M_Discoverypublisher"^^xsd:string ;
    vivo:abbreviation "FT_F2_M_Discoverypublisher"^^xsd:string ;
    dcterms:description """FAIR Test - F2 - Metadata - Has Publisher Information evaluates whether the metadata includes explicit information regarding the organisation responsible for publishing the metadata record. It looks for a structured “publisher” field within the record. In the context of an institutional repository, this is typically the institution itself, or an external repository (like Zenodo) if the record is registering an object hosted elsewhere. The test will fail if this value is not present.
"""^^xsd:string ;
    
    
    ftr:applicationArea <http://www.fairsharing.org/ontology/subject/SRAO_0000401> ;
    
    dcat:version "0.1.0"^^xsd:string ;
    
    dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
    ftr:status "Active"@en ;
     
    dcat:endpointURL <https://fair-tests.fairsharing.org/test/ft_f2_m_discoverypublisher> ;
    dcat:endpointDescription <https://fair-tests.fairsharing.org/test_descriptions/ft_f2_m_discoverypublisher/api> ;
    
    doap:repository <https://github.com/FAIRsharing/FAIR-Tests> ;
    ftr:supportedBy <https://tools.ostrails.eu/champion>; 
    
    dpv:IsApplicableFor <https://vocabularies.coar-repositories.org/resource_types/c_1843/>;
    dcterms:creator <https://fairsharing.org/organisations/2281>; 
    
    
    
    
    
    
    dcterms:publisher  <https://orcid.org/0000-0002-6468-9260>  ; 
    dcat:contactPoint  <https://orcid.org/0000-0002-6468-9260>  . 




