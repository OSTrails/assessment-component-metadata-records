    rdfs:label "FM_F4_M_FS_providesUserSearch"^^xsd:string ;
    vivo:abbreviation "FM_F4_M_FS_providesUserSearch"^^xsd:string ;
    dcterms:description """This test assesses whether the FAIRsharing record contains at least one Data Process that includes a Search or Browse function (as identified by “Search” or “Browse” within the Name field of a Data Process), uses a User Interface access method, and supports Read or Read/Write operations. The test expects as input the FAIRsharing DOI or URL for the FAIRsharing record under evaluation."""^^xsd:string ;
    
    
